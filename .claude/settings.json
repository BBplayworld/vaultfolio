{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -20",
            "async": true,
            "asyncRewake": true,
            "timeout": 60,
            "statusMessage": "Type-checking with tsc..."
          }
        ]
      }
    ]
  }
}
